# ===================
# AI
# ===================
OPENAI_API_KEY=sk-your-openai-api-key

# ===================
# Platform
# ===================
PLATFORM_URL=http://localhost:3000

# ===================
# Publish URLs
# ===================
NEXT_PUBLIC_WEB_PUBLISH_URL=https://example.com/web
NEXT_PUBLIC_WHATSAPP_PUBLISH_URL=https://example.com/whatsapp

# ===================
# Storage
# ===================
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_your_token
REDIS_URL=redis://localhost:6379

# ===================
# Identity
# ===================
TEAM_ID=your-team-uuid
CLIENT_ID=your-client-uuid
USER_ID=your-user-uuid

# ===================
# fs-whatsapp (WhatsApp Flow Publishing)
# ===================
# URL of the running fs-whatsapp (Whatomate) instance
FS_WHATSAPP_API_URL=http://localhost:8080
# API key from fs-whatsapp (format: whm_<32_hex_chars>)
# Generate one via fs-whatsapp admin panel or database
FS_WHATSAPP_API_KEY=whm_your-api-key
